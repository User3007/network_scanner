{ 
  "name": "network-scanner-webapp", 
  "version": "1.0.0", 
  "description": "A simplified network scanner web application", 
  "main": "server/index.js", 
  "scripts": { 
    "dev": "concurrently \"npm run server\" \"npm run client\"", 
    "server": "nodemon server/index.js", 
    "client": "cd client && npm start", 
    "build": "cd client && npm run build", 
    "install-all": "npm install && cd client && npm install" 
  }, 
  "dependencies": { 
    "express": "^4.18.2", 
    "cors": "^2.8.5", 
    "socket.io": "^4.7.2" 
  }, 
  "devDependencies": { 
    "nodemon": "^3.0.1", 
    "concurrently": "^8.2.0" 
  }, 
  "keywords": ["network", "scanner", "dashboard", "webapp"], 
  "author": "Network Scanner Team", 
  "license": "MIT" 
} 
